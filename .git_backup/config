[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "upstream"]
	url = git@github.com:danqueve/imperio-cierres.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
[lfs]
	repositoryformatversion = 0
[remote "origin"]
	url = git@github.com:danqueve/cierre.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[gui]
	wmstate = zoomed
	geometry = 893x435+52+52 419 375
