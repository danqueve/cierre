# ═══════════════════════════════════════════════════════
#  PROTECCIÓN DE ARCHIVOS SENSIBLES
#  Sintaxis Apache 2.4 (compatible con WAMP 3.x)
# ═══════════════════════════════════════════════════════

# Bloquear archivos sensibles por extensión
<FilesMatch "\.(env|sql|log|sh|bak)$">
    Require all denied
</FilesMatch>

# Bloquear archivos de test y debug
<FilesMatch "^(debug_test|test_dashboard|test_feedback|test_forms|test_header|test_historial|test_print_toast|test_styles|migrate_password)\.(php|html)$">
    Require all denied
</FilesMatch>

# ═══════════════════════════════════════════════════════
#  CONTENT SECURITY POLICY
#  Permite: Google Charts, Google Fonts, Lucide CDN
# ═══════════════════════════════════════════════════════
<IfModule mod_headers.c>
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.jsdelivr.net https://www.gstatic.com https://www.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://www.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://www.gstatic.com; connect-src 'self'; frame-src https://www.google.com;"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
